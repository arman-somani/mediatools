{
  "manifest_version": 3,
  "name": "MediaTools WASM Downloader",
  "version": "2.0",
  "description": "Download 1080p YouTube videos natively in your browser using WebAssembly.",
  "permissions": [
    "activeTab",
    "downloads",
    "offscreen"
  ],
  "host_permissions": [
    "*://*.youtube.com/*",
    "*://*.googlevideo.com/*"
  ],
  "background": {
    "service_worker": "background.bundle.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [ "*://localhost/*", "*://127.0.0.1/*", "*://*.mediatools.com/*", "*://*.vercel.app/*" ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
  }
}
